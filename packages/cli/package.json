{
  "name": "@labelgrid/cli",
  "version": "0.1.1",
  "description": "Official LabelGrid CLI — manage your catalog, releases, distribution and royalties from the terminal",
  "type": "module",
  "keywords": ["labelgrid", "music-distribution", "cli"],
  "main": "dist/program.js",
  "bin": {
    "labelgrid": "dist/index.js"
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --exclude 'test/contract/**'",
    "test:contract": "vitest run test/contract"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/labelgrid/labelgrid-mcp.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@labelgrid/core": "0.1.0",
    "commander": "^14.0.0"
  }
}
