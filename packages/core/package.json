{
  "name": "@labelgrid/core",
  "version": "0.2.0",
  "description": "Shared LabelGrid public-API client: HTTP transport, uploads, content types, the catalog-entity registry, and redacting logging",
  "type": "module",
  "keywords": [
    "labelgrid",
    "music-distribution",
    "api-client"
  ],
  "main": "dist/index.js",
