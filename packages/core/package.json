    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/labelgrid/labelgrid-mcp.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
