# Required: your LabelGrid API token (create one in your dashboard under Profile → API Tokens)
LABELGRID_API_TOKEN=
# Optional: API base URL (defaults to production)
# LABELGRID_API_URL=https://api.labelgrid.com/api/public
# Safe writes (create/update drafts, labels, artists…) — enabled by default
# LABELGRID_ENABLE_WRITES=true
# Full writes (distribution, takedowns, immutable uploads) — disabled by default.
# Enabling requires BOTH flags below. Read the Safety section of the README first.
# LABELGRID_ENABLE_FULL_WRITES=true
# LABELGRID_FULL_WRITES_ACK=I accept responsibility for AI-driven distribution actions
# Optional: limit the tool surface, comma-separated
# LABELGRID_TOOLSETS=catalog,releases,analytics,accounting,review,delivery,webhooks,reference,identity,distribution
